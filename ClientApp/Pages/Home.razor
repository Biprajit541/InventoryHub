@page "/"

@using System.Text.Json
@using ClientApp.Models
@inject HttpClient Http

<PageTitle>Dashboard - InventoryHub</PageTitle>

<h1 class="mb-2">📦 Dashboard</h1>

<p class="text-muted mb-4">
    Welcome to InventoryHub, a full-stack inventory management system powered by
    Blazor WebAssembly and ASP.NET Core Minimal API.
</p>

@if (products == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary"></div>
        <p class="mt-3">Loading dashboard...</p>
    </div>
}
else
{
    <div class="row g-3 mb-4">

        <div class="col-sm-6 col-xl-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <div style="font-size:32px;">📦</div>
                    <h2 class="text-primary mt-2">@products.Length</h2>
                    <div class="text-muted">Products</div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <div style="font-size:32px;">🏷️</div>
                    <h2 class="text-success mt-2">@CategoryCount</h2>
                    <div class="text-muted">Categories</div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <div style="font-size:32px;">📊</div>
                    <h2 class="text-warning mt-2">@TotalStock</h2>
                    <div class="text-muted">Units in Stock</div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <div style="font-size:32px;">💲</div>
                    <h2 class="text-danger mt-2">
                        $@AveragePrice.ToString("F2")
                    </h2>
                    <div class="text-muted">Average Price</div>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-header bg-dark text-white">

            <strong>System Overview</strong>

        </div>

        <div class="card-body">

            <p class="mb-4">
                InventoryHub demonstrates seamless communication between a
                Blazor WebAssembly front-end and an ASP.NET Core Minimal API
                back-end while using structured JSON, CORS configuration,
                in-memory caching, and Microsoft Copilot-assisted development.
            </p>

            <div class="d-flex flex-wrap gap-2">

                <span class="badge bg-primary p-2">
                    API Integration
                </span>

                <span class="badge bg-success p-2">
                    Nested JSON
                </span>

                <span class="badge bg-warning text-dark p-2">
                    CORS
                </span>

                <span class="badge bg-info text-dark p-2">
                    In-Memory Cache
                </span>

                <span class="badge bg-secondary p-2">
                    Error Handling
                </span>

                <span class="badge bg-dark p-2">
                    Performance Optimization
                </span>

                <span class="badge bg-primary p-2">
                    Blazor WebAssembly
                </span>

                <span class="badge bg-success p-2">
                    Minimal API
                </span>

                <span class="badge bg-danger p-2">
                    Microsoft Copilot
                </span>

            </div>

        </div>

    </div>
}

@code {

    private Product[]? products;

    private int CategoryCount =>
        products?
            .Select(p => p.Category?.Name)
            .Distinct()
            .Count() ?? 0;

    private int TotalStock =>
        products?.Sum(p => p.Stock) ?? 0;

    private double AveragePrice =>
        products?.Average(p => p.Price) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var json = await Http.GetStringAsync("api/productlist");

            products = JsonSerializer.Deserialize<Product[]>(
                json,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
        }
        catch
        {
            products = Array.Empty<Product>();
        }
    }

}